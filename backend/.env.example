# ============================================================
# Variables de entorno — Sistema de Inventario "La Esquina"
# Copia este archivo como .env y ajusta los valores.
# NO subas el archivo .env real al repositorio.
# ============================================================

# --- Servidor ---
PORT=4000

# --- Base de datos (XAMPP / MySQL / MariaDB) ---
# Valores por defecto de una instalación típica de XAMPP:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=la_esquina

# --- Autenticación (JWT) ---
# Cambia este secreto por una cadena larga y aleatoria en producción.
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# --- CORS ---
# El frontend se sirve desde el propio backend (http://localhost:4000/app),
# por lo que en desarrollo CORS queda abierto (*). En producción, restríngelo
# a los orígenes reales separados por comas, p. ej.:
#   CORS_ORIGIN=https://midominio.com,https://www.midominio.com
CORS_ORIGIN=*
